{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BacklogTask",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "priority",
    "risk",
    "needs_research",
    "dependencies",
    "acceptance",
    "status",
    "passes"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "priority": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "risk": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "needs_research": {
      "type": "boolean"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "todo",
        "in_progress",
        "blocked",
        "done"
      ]
    },
    "passes": {
      "type": "boolean"
    }
  }
}
